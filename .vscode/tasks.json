{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Frontend Dev Server",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location Frontend; npm install; npm run dev"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Backend Spring Boot",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location Backend; .\\mvnw spring-boot:run"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}